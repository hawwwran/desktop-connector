# Route all requests through public/index.php
# Protect src/, data/, storage/, migrations/ from direct access

RewriteEngine On
RewriteBase /SERVICES/desktop-connector/

# Block direct access to protected directories and files
RewriteRule ^src/ - [F,L]
RewriteRule ^data/ - [F,L]
RewriteRule ^storage/ - [F,L]
RewriteRule ^migrations/ - [F,L]
RewriteRule ^firebase-service-account\.json$ - [F,L]
RewriteRule ^google-services\.json$ - [F,L]

# Serve static brand assets from public/ without rewriting to index.php
RewriteRule ^favicon-(\d+)\.png$ public/favicon-$1.png [L]
RewriteRule ^css/(.+\.css)$ public/css/$1 [L]

# Route everything else to public/index.php
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^ public/index.php [QSA,L]
